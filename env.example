# Configuración de la aplicación
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Base de datos PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=tekoapp

# Base de datos MongoDB
MONGODB_URI=mongodb://localhost:27017/tekoapp

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=tu_clave_secreta_muy_segura_aqui
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Google Maps API
GOOGLE_MAPS_API_KEY=tu_api_key_de_google_maps

# Firebase
FIREBASE_PROJECT_ID=tu_proyecto_firebase
FIREBASE_PRIVATE_KEY=tu_clave_privada_firebase
FIREBASE_CLIENT_EMAIL=tu_email_cliente_firebase

# Stripe
STRIPE_SECRET_KEY=tu_clave_secreta_stripe
STRIPE_WEBHOOK_SECRET=tu_webhook_secret_stripe

# AWS S3 (para subida de archivos)
AWS_ACCESS_KEY_ID=tu_access_key_aws
AWS_SECRET_ACCESS_KEY=tu_secret_key_aws
AWS_REGION=us-east-1
AWS_S3_BUCKET=tekoapp-uploads

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_password_de_aplicacion

# Twilio (SMS)
TWILIO_ACCOUNT_SID=tu_account_sid_twilio
TWILIO_AUTH_TOKEN=tu_auth_token_twilio
TWILIO_PHONE_NUMBER=tu_numero_twilio

# Configuración de la aplicación
APP_NAME=TekoApp
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Configuración de pagos
PAYMENT_CURRENCY=PYG
PAYMENT_MIN_AMOUNT=10000
PAYMENT_MAX_AMOUNT=1000000

# Configuración de geolocalización
DEFAULT_RADIUS_KM=10
MAX_RADIUS_KM=50

# Configuración de notificaciones
PUSH_NOTIFICATIONS_ENABLED=true
SMS_NOTIFICATIONS_ENABLED=true
EMAIL_NOTIFICATIONS_ENABLED=true
