# ⚙️ CONFIGURACIÓN GENERAL DEL PROYECTO
PROJECT_NAME=TekoApp
PROJECT_DESCRIPTION="Plataforma de Servicios Profesionales en Tiempo Real"
BASE_URL=http://localhost:3000
PORT=3000
NODE_ENV=develop
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:10005
# Origen del frontend web (TekoApp-Frontend-Web) — usado por LocationsGateway (CORS del WebSocket),
# separado de ALLOWED_ORIGINS (CORS HTTP normal, configurado arriba)
FRONTEND_URL=http://localhost:3001
# Secret del cliente Basic Auth "tekoapp-web" — debe coincidir con BACKEND_CLIENT_SECRET
# en TekoApp-Frontend-Web/.env.local. Ver prisma/seed.ts.
WEB_CLIENT_SECRET=dev-only-change-me

# 📊 OBSERVABILIDAD (SEQ LOGS)
SEQ_ENABLED=false
SEQ_URL=http://localhost:5341

# 🐘 PERSISTENCIA PRINCIPAL (POSTGRESQL & PRISMA)
DATABASE_URL="postgresql://postgres:password@localhost:5432/tekoapp?schema=public"
DATABASE_CONNECTION_STRING="postgresql://postgres:password@localhost:5432/tekoapp?schema=public"
AUDIT_SECRET_PEPPER="change-me-generate-a-random-secret-per-environment"

# 🍃 TELEMETRÍA Y GEOLOCALIZACIÓN HISTÓRICA (MONGODB)
MONGODB_URI=mongodb://localhost:27017/tekoapp
MONGODB_MAX_POOL_SIZE=10

# 🐂 COLAS DE TAREAS Y CACHE (REDIS & BULL)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 🔐 AUTENTICACIÓN (JWT ASIMÉTRICO RSA)
# Nota: Reemplazar por tus llaves reales generadas. Conservamos los \n del Starter.
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEogIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...\n-----END PUBLIC KEY-----"
ACCESS_TOKEN_EXPIRES=15m
TEMP_TOKEN_EXPIRES=1h
REFRESH_TOKEN_EXPIRES=7d
REFRESH_TOKEN_SHORT_EXPIRES=12h

# 📧 SERVICIO DE CORREO (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_password_de_aplicacion_ej_abcd_efgh_ijkl_mnop
EMAIL_DIR=soporte@tekoapp.com.py

# 📦 ALMACENAMIENTO DE ARCHIVOS (AWS S3 / MINIO)
S3_ACCESS_KEY_ID=tu_access_key_aws
S3_SECRET_ACCESS_KEY=tu_secret_key_aws
S3_BUCKET_NAME=tekoapp-uploads
S3_REGION=us-east-1
S3_MAX_CONCURRENCY=5
S3_RETRY_ATTEMPTS=3
S3_RETRY_DELAY_MS=250
S3_PRESIGNED_URL_EXPIRES_IN=900

# 📍 GEOLOCALIZACIÓN Y GOOGLE MAPS API
GOOGLE_MAPS_API_KEY=tu_api_key_de_google_maps
DEFAULT_RADIUS_KM=10
MAX_RADIUS_KM=50

# 🔥 NOTIFICACIONES PUSH & MOBILE (FIREBASE)
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@tu-proyecto.iam.gserviceaccount.com

# 💳 PASARELA DE PAGOS (STRIPE / BANCARD FUTURO)
STRIPE_SECRET_KEY=sk_test_51...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYMENT_CURRENCY=PYG
PAYMENT_MIN_AMOUNT=10000
PAYMENT_MAX_AMOUNT=1000000

# 💬 MENSAJERÍA SMS (TWILIO)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=tu_auth_token_twilio
TWILIO_PHONE_NUMBER=+1234567890